; Forgejo app.ini — generated by Ansible role forgejo
; Cell: {{ cell_id }}
; Do not edit manually — managed by ansible/roles/forgejo

[DEFAULT]
RUN_USER = {{ forgejo_user }}
RUN_MODE = prod

[server]
DOMAIN           = {{ fqdn }}
HTTP_PORT        = {{ forgejo_port }}
ROOT_URL         = http://{{ fqdn }}:{{ forgejo_port }}/
SSH_DOMAIN       = {{ fqdn }}
SSH_PORT         = {{ forgejo_ssh_port }}
APP_DATA_PATH    = {{ forgejo_data }}
DISABLE_SSH      = false
START_SSH_SERVER = true

[database]
DB_TYPE  = {{ forgejo_db_type }}
PATH     = {{ forgejo_db_path }}

[repository]
ROOT = {{ forgejo_data }}/repositories

[log]
ROOT_PATH = {{ forgejo_data }}/log
LEVEL     = {{ forgejo_log_level }}

[security]
INSTALL_LOCK        = true
SECRET_KEY          = {{ forgejo_secret_key | default('REPLACE_WITH_GENERATED_SECRET') }}
INTERNAL_TOKEN      = {{ forgejo_internal_token | default('REPLACE_WITH_GENERATED_TOKEN') }}

[service]
DISABLE_REGISTRATION              = false
REQUIRE_SIGNIN_VIEW               = false
ENABLE_NOTIFY_MAIL                = false
DEFAULT_KEEP_EMAIL_PRIVATE        = true
DEFAULT_ALLOW_CREATE_ORGANIZATION = true
